# Moonshot Kimi API 配置
MOONSHOT_API_KEY=sk-xxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-32k-vision-preview

# 数据库配置
DATABASE_URL=sqlite:///./essay_correction.db

# 上传文件存储目录
UPLOAD_DIR=./uploads

# 后端服务配置
HOST=0.0.0.0
PORT=8000

# OCR 引擎配置（可选）
# 百度 OCR
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 腾讯 OCR
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=

# 批量批改目录
BATCH_SCAN_DIR=/mnt/hgfs/vm_share/workspace/essay-correction
